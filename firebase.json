{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/resume",
        "destination": "/pages/resume/index.html"
      },
      {
        "source": "/links",
        "destination": "/pages/links/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
